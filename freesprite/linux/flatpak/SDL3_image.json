{
    "name": "SDL3_image",
    "buildsystem": "cmake-ninja",
    "builddir": true,
    "config-opts": [
        "-DCMAKE_VERBOSE_MAKEFILE=ON",
        "-DCMAKE_BUILD_TYPE:STRING=Release",
        "-DCMAKE_INSTALL_LIBDIR:PATH=lib"
    ],
    "sources": [
        {
            "type": "dir",
            "path": "../../../external/SDL_image"
        }
    ],
    "cleanup": [
        "/include",
        "/lib/*.la",
        "/lib/*.a",
        "/lib/cmake",
        "/share/aclocal",
        "/lib/pkgconfig"
    ]
}
